// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"

}

// 선생님의 엑셀 데이터를 통째로 저장할 테이블
model Spreadsheet {
  id        Int      @id @default(autoincrement())
  title     String   @default("생활관지도일지")
  
  // 컬럼명과 행 데이터를 JSON 문자열 형태로 저장 (유연성 확보)
  columns   String   
  rows      String   
  
  updatedAt DateTime @updatedAt
}